# Local environment example for development and deployment notes
# Copy this file to `.env.local` for local development and DO NOT commit
# the copied `.env.local` file to your repository. Use your host's dashboard
# to set the same variables for production.

# ─── NextAuth ───────────────────────────────────────────────
# Generate a secure secret locally: `openssl rand -base64 32`
NEXTAUTH_SECRET=replace_with_a_secure_generated_value
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# For local testing set the redirect URI to: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Google reCAPTCHA v3 ─────────────────────────────────────
# If not using reCAPTCHA in development you can leave these empty.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
